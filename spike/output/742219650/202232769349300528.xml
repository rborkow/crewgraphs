      <MissionDesc>AUSTIN ROWING CLUB (ARC) IS DEDICATED TO ADVANCING THE SPORT OF ROWING THROUGH QUALITY PROGRAMMING AND REGATTAS IN AUSTIN, TEXAS. ARC PROVIDES BEGINNER, RECREATIONAL, AND COMPETITIVE PROGRAMS FOR YOUTH AND ADULTS, AND OUTREACH PROGRAMS FOR THE AUSTIN COMMUNITY.</MissionDesc>
      <SignificantNewProgramSrvcInd>false</SignificantNewProgramSrvcInd>
      <SignificantChangeInd>false</SignificantChangeInd>
      <ExpenseAmt>705815</ExpenseAmt>
