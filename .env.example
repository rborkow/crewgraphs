DATABASE_URL=postgres://username:password@host:5432/crewgraphs

# Role passwords for db/migrations grants (see SETUP.md)
NEON_PIPELINE_RW_ROLE_PASSWORD=
NEON_CURATOR_ROLE_PASSWORD=
NEON_WEB_RO_ROLE_PASSWORD=

# Used by wrangler/miniflare to emulate the HYPERDRIVE binding in local dev
# and during `opennextjs-cloudflare deploy`. Point at the web_ro role.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://web_ro:password@host:5432/crewgraphs?sslmode=require
