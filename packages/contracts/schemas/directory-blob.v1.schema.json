{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "snapshot_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "data_through_label": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "org_id": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "slug": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "city": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "org_type": {
            "type": "string",
            "enum": [
              "community_club",
              "private_membership_club",
              "scholastic_program",
              "collegiate_varsity",
              "collegiate_club",
              "university_support_foundation",
              "booster_club",
              "adaptive_program",
              "association",
              "governing_body",
              "other"
            ]
          },
          "program_mix": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "peer_cohorts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coverage_state": {
            "type": "string",
            "enum": [
              "990",
              "990ez",
              "990n_only",
              "none"
            ]
          },
          "filing_years": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          },
          "latest_tax_year": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ]
          },
          "latest_total_revenue": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "fye_month": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1,
                "maximum": 12
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "org_id",
          "slug",
          "display_name",
          "aliases",
          "city",
          "state",
          "org_type",
          "program_mix",
          "peer_cohorts",
          "coverage_state",
          "filing_years",
          "latest_tax_year",
          "latest_total_revenue",
          "fye_month"
        ]
      }
    }
  },
  "required": [
    "snapshot_id",
    "published_at",
    "data_through_label",
    "entries"
  ]
}
